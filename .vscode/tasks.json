{
	"version": "2.0.0",
	"tasks": [
		{
			"group": "test",
			"label": "unocss cli watch",
			"type": "shell",
			"detail": "运行 unocss cli(带有监视 CSS 生成), 输出到 assets/csss/uno.css",
			"icon": {
				"color": "terminal.ansiGreen",
				"id": "activate-breakpoints"
			},
			// https://unocss.dev/integrations/cli
			// \"command": "unocss \"layouts/**/*.html\" \"config/**/*.toml\" \"content/**/**.md\" --watch --out-file assets/css/uno.css",
			"command": "unocss",
			"args": [
				// 请将要渲染的文件按照如下格式渲染
				"\"config/**/*.toml\"",
				"\"content/**/*.md\"",
				"\"layouts/**/*.html\"",
				"-w", // "--watch", 监听 unocss 生成
				"-o", // "--out-file", 输出文件至 uno.css
				"assets/css/uno.css"
			],
			"presentation": {
				"echo": true,
				"reveal": "silent",
				"focus": false, // 默认不聚焦，
			},
		
		},
		{
			"group": "test",
			"type": "shell",
			"command": "hugo",
			"args": [
				"server",
				"--buildDrafts"
			],
			"label": "hugo server draft",
			"detail": "运行 Hugo 服务器",
			"icon": {
				"color": "terminal.ansiMagenta",
				"id": "server"
			},
			"presentation": {
				"echo": true,
				"focus": true,
				// "reveal": "always",
			}
		},
		{
			"group": {
				"kind": "test",
				"isDefault": true
			},
			"label": "hencte.top: debug",
			"detail": "调试整个 Hugo 站点",
			"icon": {
				"color": "terminal.ansiRed",
				"id":"debug"
			},
			"dependsOn": [
				"unocss cli watch",
				"hugo server draft"
			],
		}
	]
}